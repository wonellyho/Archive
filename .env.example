# Copy this file to ".env" and fill in your own values.

# --- YouTube Data API v3 ---
# https://console.cloud.google.com → enable "YouTube Data API v3".
# NOTE: this key is bundled into the client. Restrict it in Google Cloud Console
# (HTTP referrers + YouTube Data API only) before deploying publicly.
VITE_YOUTUBE_API_KEY=

# --- Supabase (data storage + owner login) ---
# Supabase project → Settings → API. The anon key is safe to expose; Row Level
# Security protects writes. If these are empty, the app falls back to localStorage.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

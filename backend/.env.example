# 이 파일을 ".env"로 복사한 뒤 값을 채우세요. (.env 는 커밋 금지)

# ── 환경 ── development | production (production에서는 AUTH_OPTIONAL 무시)
ENVIRONMENT=development

# ── CORS ── 프론트 개발 서버 주소 (콤마로 여러 개)
FRONTEND_ORIGINS=http://localhost:5173

# ── Supabase (Project Settings → API) ──
# JWT 검증은 SUPABASE_URL 기반 JWKS(ES256 공개키)로 수행됩니다. URL만 있으면 됨.
SUPABASE_URL=
# 레거시 HS256 프로젝트에서만 설정 (이 프로젝트는 ECC P-256 → 비워두세요)
SUPABASE_JWT_SECRET=
# 공개 읽기용 — 루트 .env의 VITE_SUPABASE_ANON_KEY와 같은 값
SUPABASE_ANON_KEY=
# 쓰기용 서버 전용 비밀키(절대 프론트 노출 금지) — 쓰기 API부터 필요
SUPABASE_SERVICE_ROLE_KEY=

# ── YouTube Data API v3 ── 서버 전용! 절대 프론트/커밋에 노출 금지
YOUTUBE_API_KEY=

# ── Claude API (LLM 문구추천 /api/llm/suggest) ── 서버 전용! LLM 기능에 필수.
# console.anthropic.com에서 발급. 크레딧 필요(문구추천 1회 ≈ 0.1센트 미만).
ANTHROPIC_API_KEY=
# (선택) 기본값 있음 — 바꿀 때만 설정
LLM_MODEL=claude-haiku-4-5
LLM_MAX_TOKENS=400
LLM_RATE_PER_MIN=10

# ── 이미지 업로드 (/api/uploads) ──
# ⚠️ Supabase 대시보드에 공개 버킷 하나 필요(docs/supabase-setup.md §1-1).
STORAGE_BUCKET=images
MAX_UPLOAD_BYTES=2097152   # 2MB (선택)

# ── 개발용 ── true면 토큰 없이도 API 통과(로컬 통합용, 배포 환경 금지)
# ⚠️ 마이그레이션(user_id) 후에는 DB '쓰기'는 실토큰 필요(가짜 유저는 FK 위반).
#    읽기·YouTube 검색·LLM은 AUTH_OPTIONAL=true로 토큰 없이 테스트 가능.
AUTH_OPTIONAL=false

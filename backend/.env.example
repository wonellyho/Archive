# 이 파일을 ".env"로 복사한 뒤 값을 채우세요. (.env 는 커밋 금지)

# ── 환경 ── development | production (production에서는 AUTH_OPTIONAL 무시)
ENVIRONMENT=development

# ── CORS ── 프론트 개발 서버 주소 (콤마로 여러 개)
FRONTEND_ORIGINS=http://localhost:5173

# ── Supabase (Project Settings → API) ──
# JWT 검증은 SUPABASE_URL 기반 JWKS(ES256 공개키)로 수행됩니다. URL만 있으면 됨.
SUPABASE_URL=
# 레거시 HS256 프로젝트에서만 설정 (이 프로젝트는 ECC P-256 → 비워두세요)
SUPABASE_JWT_SECRET=
# 공개 읽기용 — 루트 .env의 VITE_SUPABASE_ANON_KEY와 같은 값
SUPABASE_ANON_KEY=
# 쓰기용 서버 전용 비밀키(절대 프론트 노출 금지) — 쓰기 API부터 필요
SUPABASE_SERVICE_ROLE_KEY=

# ── YouTube Data API v3 ── 서버 전용! 절대 프론트/커밋에 노출 금지
YOUTUBE_API_KEY=

# ── Claude API (추후 LLM 기능) ──
ANTHROPIC_API_KEY=

# ── 개발용 ── true면 토큰 없이도 API 통과(로컬 통합용, 배포 환경 금지)
AUTH_OPTIONAL=false
